{
    "name": "avathar/quickstyle",
    "type": "phpbb-extension",
    "description": "Adds a style dropdown box to the header of every page for quickly switching between styles. Based on the original Prime Quick Style by primehalo.",
    "homepage": "https://www.avathar.be/forum/viewtopic.php?f=2&t=4520",
    "version": "2.0.1",
    "time": "2026-04-02",
    "license": "GPL-2.0-only",
    "authors": [
        {
            "name": "Sajaki",
            "email": "info@avathar.be",
            "homepage": "https://www.avathar.be/",
            "role": "Developer"
        },
        {
            "name": "PayBas",
            "homepage": "http://www.paybas.com",
            "role": "Previous Developer"
        },
        {
            "name": "primehalo",
            "homepage": "http://www.absoluteanime.com",
            "role": "Original Developer"
        }
    ],
    "require": {
        "php": ">=8.0",
        "composer/installers": "~1.0 || ~2.0"
    },
    "extra": {
        "display-name": "Quick Style",
        "soft-require": {
            "phpbb/phpbb": ">=3.3.0"
        },
        "version-check": {
            "host": "www.avathar.be",
            "directory": "/versioncheck",
            "filename": "quickstyle.json",
            "ssl": true
        }
    }

}
